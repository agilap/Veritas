# TruthScan — Environment Variables
# Copy to .env and fill in. On HF Spaces use Space Secrets instead.

# ── X / Twitter (Layer 0) ───────────────────────────────────────────────────
# Free Bearer Token at: https://developer.x.com → Projects & Apps → Keys
# Read-only, free tier: 500k tweet reads/month — more than enough
TWITTER_BEARER_TOKEN=your_bearer_token_here

# ── Facebook (Layer 0 — optional) ───────────────────────────────────────────
# Most public Facebook posts scrape without login.
# For login-walled content, export your cookies with "EditThisCookie" extension
# and point to the JSON file here:
FACEBOOK_COOKIES_FILE=

# ── Reddit (Layer 4) ────────────────────────────────────────────────────────
# Create a "script" app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=TruthScan/1.0 by YourUsername

# ── GNews (Layer 4) ─────────────────────────────────────────────────────────
# Free tier at https://gnews.io — 100 requests/day
GNEWS_API_KEY=your_gnews_api_key
